{
  "name": "@wispr/skill",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "wispr-mcp": "./dist/mcp-server.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
