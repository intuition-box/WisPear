    "seed:test": "tsx src/seed/seed-intuition.ts --test",
    "seed:full": "tsx src/seed/seed-intuition.ts --full"
  },
  "dependencies": {
    "ethers": "^6.13.4",
    "dotenv": "^16.4.5",
    "pinata": "^1.3.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.2"
  }
}
